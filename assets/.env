# ==========================================
# Official project defaults (versioned)
# Precedence: CLI > assets/.env_user > assets/.env > code fallback
# ==========================================

# Required for real run (can be overridden by CLI)
PROJECT_PATH=
FACE_MODEL_NAME=
FORMAT=image
INPUT_PATH=

# Optional overrides
OUTPUT_PATH=
OUTPUT_SUFFIX=
PRELOAD_MODELS=false

# Pipeline switches
USE_SWAPER=true
USE_RESTORE=true
USE_PARSER=true
RESTORE_CHOICE=1
PARSER_CHOICE=1

# Runtime
WORKERS_PER_STAGE=8
WORKER_QUEUE_SIZE=64
OUT_QUEUE_SIZE=128
TUNER_MODE=auto
GPU_TARGET_UTIL=95
HIGH_WATERMARK=12
LOW_WATERMARK=4
SWITCH_COOLDOWN_S=0.35
MAX_FRAMES=0
MAX_RETRIES=2
SKIP_EXISTING=true

# Restore / Parser tuning
SWAPER_WEIGH=1.00
RESTORE_WEIGH=1.00
RESTORE_BLEND=1.00
PRESERVE_SWAP_EYES=true
PARSER_MASK_BLUR=21

# Logging / validation
DRY_RUN=false
PRINT_EFFECTIVE_CONFIG=false
LOG_LEVEL=warning

# Providers
PROVIDER_ALL=trt
PROVIDER_DETECT=auto
PROVIDER_SWAPER=auto
PROVIDER_RESTORE=auto
PROVIDER_PARSER=auto
